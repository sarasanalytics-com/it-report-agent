# Copy to bot/.env and fill in. (Do NOT commit the real .env.)

# ── Slack ───────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token        # OAuth & Permissions → Bot User OAuth Token
SLACK_APP_TOKEN=xapp-your-app-token        # Basic Information → App-Level Token (connections:write)

# ── Claude ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5           # optional default; claude-sonnet-4-6 for higher quality

# ── Live data: Microsoft Graph / SharePoint (same as the report workflow) ────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
ASSET_FILE_PATH=
SPEND_FILE_PATH=
PROCUREMENT_FILE_PATH=
JOINERS_FILE_PATH=
VENDOR_FILE_PATH=

# ── Live data: ClickUp IT tickets ───────────────────────────────────────────
CLICKUP_API_TOKEN=
CLICKUP_IT_ISSUES_LIST_ID=

# ── Access control ──────────────────────────────────────────────────────────
# Comma-separated Slack user IDs allowed to use the bot (e.g. the HR head + IT).
# Find an ID in Slack: click the person's name → "More" → "Copy member ID".
# Leave EMPTY to allow everyone who can DM/@mention the bot (not recommended).
BOT_ALLOWED_USERS=U01ABCDEF,U02GHIJKL

# ── Question log (web page) ─────────────────────────────────────────────────
# The bot serves a web page listing every question asked (and a CSV download).
# LOG_VIEW_TOKEN — if set, the page requires ?token=<value>. SET THIS (questions
#   can contain employee names). Leave empty only for a quick private test.
LOG_VIEW_TOKEN=
# QUESTION_LOG_DIR — where the log file is kept. On Render the disk is ephemeral,
#   so point this at a mounted persistent disk to keep history across deploys.
# QUESTION_LOG_DIR=/var/data
# PORT is provided by Render automatically (defaults to 3000 locally).

# ── Optional tuning ─────────────────────────────────────────────────────────
# INR_TO_USD_RATE=85.5
# BOT_REPORT_TYPE=monthly        # monthly (default) = most complete context
# DATA_REFRESH_TTL=600           # seconds to reuse fetched data before refreshing
# BOT_MAX_TOKENS=900
